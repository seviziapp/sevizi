{
  "expo": {
    "name": "Sèvizi",
    "slug": "sevizi",
    "scheme": "sevizi",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon-square.png",
    "splash": {
      "image": "./assets/favicon.png",
      "backgroundColor": "#06291F",
      "resizeMode": "contain"
    },
    "web": {
      "favicon": "./assets/icon-square.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "tg.sevizi.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Sèvizi utilise votre position pour poser votre point sur la carte et trouver les prestataires proches."
      }
    },
    "android": {
      "package": "com.weareaurum.sevizi",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon-adaptive-foreground.png",
        "backgroundColor": "#0FA76A"
      },
      "versionCode": 5
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "badc3035-a82b-4277-9ecb-691751eb83ca"
      }
    },
    "owner": "weareaurum"
  }
}
